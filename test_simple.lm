// List-based loop with explicit string list type
var fruits = ["Apple", "Banana", "Cherrys"];
iter (fruit in fruits) {
    print(fruit);
}

// Tuple-based loop with explicit string list type
var fruites = ("Apples", "Bananas", "Cherries");
iter (fruit in fruites) {
    print(fruit);
}

// Dictionary-based loop with defined key/value type
//type DictOfStrToInt = {str: int};
var my_dict = { "at": 1, "bi": 12, "fce": 78, "de": 2898 };
iter (entry in my_dict) {
    print("{entry.key}: {entry.value}");
}
