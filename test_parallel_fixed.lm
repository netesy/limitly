// Test parallel blocks with fixed syntax and types
print("=== Parallel Block Tests (Fixed) ===");

// ==========================================
//  Simple parallel block with iter
// ==========================================
var counter = 0;
var results = channel();

parallel(cores=4) {
    iter(i in 0..99) {
        results.send(i * 2);
        counter = counter + 1;
    }
}

print("Parallel processing complete");
print("Counter: {counter}");

// Collect results
var result_count = 0;
var first_result = 0;
var last_result = 0;

iter (result in results) {
    if (result_count == 0) {
        first_result = result;
    }
    last_result = result;
    result_count = result_count + 1;
}

print("Results collected: {result_count}");
print("First result: {first_result}");
print("Last result: {last_result}");

// ==========================================
//  Parallel block with multiple cores
// ==========================================
var results2 = channel();
var task_count = 0;

parallel(cores=8) {
    iter(i in 0..199) {
        results2.send(i * 3);
        task_count = task_count + 1;
    }
}

print("Second parallel block complete");
print("Tasks executed: {task_count}");

// Collect and verify results
var sum = 0;
iter (result in results2) {
    sum = sum + result;
}

print("Sum of results: {sum}");

// ==========================================
//  Parallel block with smaller range
// ==========================================
var results3 = channel();

parallel(cores=2) {
    iter(i in 0..9) {
        results3.send(i * 10);
    }
}

print("Third parallel block complete");

// Display results
iter (result in results3) {
    print("  Result: {result}");
}
