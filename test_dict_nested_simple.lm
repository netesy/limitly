print("=== Nested Dict Test ===");

var inner = {"x": 10, "y": 20};
print("Inner dict created");

var outer = {"a": inner};
print("Outer dict created");

var retrieved = outer["a"];
print("Retrieved inner dict: {retrieved}");

var x_val = retrieved["x"];
print("x value: {x_val}");

print("Test complete");
