print("=== Basic Parallel Block Test ===");

var counter = 0;
var results: list = [];

parallel {
    iter(i in 0..9) {
        results[i] = i * 2;
        counter = counter + 1;
    }
}

print("Parallel processing complete");
print("Counter: {counter}");
print("First result: {results[0]}");
print("Last result: {results[9]}");
