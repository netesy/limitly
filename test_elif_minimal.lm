var score = 75;
assert(score == 75, "Score should be 75");

print("Grade calculation: ");
var grade = "";
if (score >= 90) {
    grade = "A";
    // assert(false, "Score 75 should not get grade A");
} elif (score >= 80) {
    grade = "B";
    // assert(false, "Score 75 should not get grade B");
} elif (score >= 70) {
    grade = "C";
    // assert(score >= 70, "Score 75 should get grade C");
} else {
    grade = "F";
    // assert(false, "Score 75 should not get grade F");
}

// assert(grade == "C", "Score 75 should result in grade C");
print("Grade: {grade}");
print("done");
