// test_oop_module.lm
import oop_module;

fn main() {
    print("Testing OOP module system...");

    // Test frame instantiation and method call from module
    var p1 = Person(name="Alice", age=30);
    p1.greet();

    // Test function from module that returns a frame
    var p2 = create_person("Bob", 25);
    p2.greet();

    print("OOP module test completed.");
}

main();
