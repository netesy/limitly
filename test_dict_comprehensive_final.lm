// Comprehensive dict functionality test
print("=== Comprehensive Dict Test ===");

// Test 1: Dict creation and printing
print("Test 1: Dict creation and printing");
var scores = { "alice": 95, "bob": 87, "charlie": 92 };
print("Scores: {scores}");

// Test 2: Dict iteration with tuple unpacking
print("Test 2: Dict iteration with tuple unpacking");
iter (entry in scores) {
    print("Entry: {entry}");
}

// Test 3: Dict iteration with key/value access
print("Test 3: Dict iteration with key/value access");
iter (entry in scores) {
    var key = entry;
    print("Key-Value pair: {key}");
}

// Test 4: Empty dict
print("Test 4: Empty dict");
var empty = {};
print("Empty dict: {empty}");

// Test 5: Dict with different value types
print("Test 5: Dict with different value types");
var mixed = { "name": "Limit", "version": 1, "active": true };
print("Mixed dict: {mixed}");

// Test 6: Multiple dicts
print("Test 6: Multiple dicts");
var dict1 = { "a": 1, "b": 2 };
var dict2 = { "x": 10, "y": 20 };
print("Dict1: {dict1}");
print("Dict2: {dict2}");

// Test 7: Dict in loop
print("Test 7: Dict in loop");
var counter = 0;
iter (entry in dict1) {
    counter = counter + 1;
    print("Iteration {counter}: {entry}");
}

print("=== All dict tests passed ===");
