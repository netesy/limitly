print("=== Parallel Block with Iter Test ===");

var counter = 0;
var results = channel();

parallel {
    iter(i in 0..9) {
        results.send(i * 2);
        counter = counter + 1;
    }
}

print("Parallel processing complete");
print("Counter: {counter}");
print("Results:");

iter (result in results) {
    print("  Result: {result}");
}
