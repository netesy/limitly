// Test 2: Second concurrent block from smoke test
print("=== Concurrency Smoke Test - Block 2 ===");

// Channel for communication
var results = channel();

print("Testing concurrent task iteration");

// Fixed iteration block - using channels only (no SharedCell)
concurrent(ch=results, cores=2, on_error=Stop) {
    task(i in 1..4) {
        print("Task {i} running");
        results.send("Task {i} completed");  // Channel communication only
    }
}

// Collect results
var task_count = 0;
iter (result in results) {
    print("Received: {result}");
    task_count = task_count + 1;
}

print("DEBUG: After first iter, task_count = {task_count}");
assert(task_count == 4, "Should receive 4 results");
print("Task tests completed");
print("Final task count: {task_count}");


// Test 2: Second concurrent block from smoke test
print("=== Concurrency Smoke Test - Block 4 ===");

// Channel for communication
var results = channel();

print("Testing concurrent task iteration");

// Fixed iteration block - using channels only (no SharedCell)
concurrent(ch=results, cores=2, on_error=Stop) {
    task(i in 5..9) {
        print("Task {i} running again");
        results.send("Task {i} completed");  // Channel communication only
    }
}

// Collect results
var task_count = 0;
iter (result in results) {
    print("Received: {result}");
    task_count = task_count + 1;
}

print("DEBUG: After second iter, task_count = {task_count}");
assert(task_count == 5, "Should receive 5 results");
print("Task tests completed");
print("Final task count: {task_count}");
