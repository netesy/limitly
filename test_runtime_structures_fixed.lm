// Test file for runtime structures (lists, dicts, tuples)
// This will test the integration between RegisterVM and C runtime functions

print("=== Testing Runtime Structures ===");

// Test basic list operations
print("\n--- List Operations ---");

// Create a new list
let my_list = [];
print("Created empty list");

// Append some values
my_list.append(42);
my_list.append("hello");
my_list.append(3.14);
print("Appended 3 values to list");

// Get values by index
let first = my_list[0];
let second = my_list[1];
let third = my_list[2];

print("First element:", first);
print("Second element:", second);
print("Third element:", third);

// Test with different types
let mixed_list = [];
mixed_list.append(100);
mixed_list.append(true);
mixed_list.append("world");
mixed_list.append(2.718);

print("Mixed list elements:");
print("  [0] =", mixed_list[0]);
print("  [1] =", mixed_list[1]);
print("  [2] =", mixed_list[2]);
print("  [3] =", mixed_list[3]);

// Test basic dictionary operations
print("\n--- Dictionary Operations ---");

// Create a new dictionary
let my_dict = {};
print("Created empty dictionary");

// Set some key-value pairs
my_dict["name"] = "Alice";
my_dict["age"] = 25;
my_dict["score"] = 95.5;
print("Set 3 key-value pairs");

// Get values by key
let name = my_dict["name"];
let age = my_dict["age"];
let score = my_dict["score"];

print("Name:", name);
print("Age:", age);
print("Score:", score);

// Test with different key types
let number_dict = {};
number_dict[1] = "one";
number_dict[2] = "two";
number_dict[3] = "three";

print("Number dictionary:");
print("  1 ->", number_dict[1]);
print("  2 ->", number_dict[2]);
print("  3 ->", number_dict[3]);

// Test tuple operations
print("\n--- Tuple Operations ---");

// Create a tuple (using tuple syntax)
let my_tuple = (1, "hello", 3.14, true);
print("Created tuple with 4 elements");

// Access tuple elements by index
let t_first = my_tuple[0];
let t_second = my_tuple[1];
let t_third = my_tuple[2];
let t_fourth = my_tuple[3];

print("Tuple elements:");
print("  [0] =", t_first);
print("  [1] =", t_second);
print("  [2] =", t_third);
print("  [3] =", t_fourth);

// Test with different types
let mixed_tuple = (42, "world", 2.718, false, 100);
print("Mixed tuple elements:");
print("  [0] =", mixed_tuple[0]);
print("  [1] =", mixed_tuple[1]);
print("  [2] =", mixed_tuple[2]);
print("  [3] =", mixed_tuple[3]);
print("  [4] =", mixed_tuple[4]);

// Test nested structures
print("\n--- Nested Structures ---");

// Create a list of dictionaries
let people = [];

let person1 = {};
person1["name"] = "Alice";
person1["age"] = 25;
people.append(person1);

let person2 = {};
person2["name"] = "Bob";
person2["age"] = 30;
people.append(person2);

print("List of people:");
print("  Person 0:", people[0]["name"], "(", people[0]["age"], "years old)");
print("  Person 1:", people[1]["name"], "(", people[1]["age"], "years old)");

// Create a dictionary with lists as values
let categories = {};
categories["numbers"] = [1, 2, 3, 4, 5];
categories["strings"] = ["apple", "banana", "cherry"];
categories["mixed"] = [42, "hello", 3.14];

print("\nDictionary with lists:");
print("  Numbers:", categories["numbers"]);
print("  Strings:", categories["strings"]);
print("  Mixed:", categories["mixed"]);

// Test error handling
print("\n--- Error Handling ---");

// Test list index out of bounds
let small_list = [1, 2, 3];
print("Testing list index out of bounds:");
print("  Valid access: small_list[1] =", small_list[1]);

// This should return nil or handle gracefully
let invalid = small_list[10];
print("  Invalid access: small_list[10] =", invalid);

// Test dictionary key not found
let small_dict = {"existing": "value"};
print("\nTesting dictionary key not found:");
print("  Valid access: small_dict['existing'] =", small_dict["existing"]);

// This should return nil or handle gracefully
let missing = small_dict["missing"];
print("  Invalid access: small_dict['missing'] =", missing);

// Test tuple index out of bounds
let small_tuple = (1, 2, 3);
print("\nTesting tuple index out of bounds:");
print("  Valid access: small_tuple[1] =", small_tuple[1]);

// This should return nil or handle gracefully
let tuple_invalid = small_tuple[10];
print("  Invalid access: small_tuple[10] =", tuple_invalid);

print("\n=== Test Summary ===");
print("✅ List operations completed");
print("✅ Dictionary operations completed");
print("✅ Tuple operations completed");
print("✅ Nested structures completed");
print("✅ Error handling tests completed");

print("\nAll runtime structure tests completed successfully!");
