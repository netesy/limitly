// test_interpreter.lm - Comprehensive interpreter test

fn factorial(n: int): int {
    if (n <= 1) {
        return 1;
    }
    return n * factorial(n - 1);
}

fn fibonacci(n: int): int {
    if (n <= 1) {
        return n;
    }
    return fibonacci(n - 1) + fibonacci(n - 2);
}

fn main() {
    print("=== Factorial Test ===");
    print("5! = {factorial(5)}");
    print("6! = {factorial(6)}");
    
    print("=== Fibonacci Test ===");
    print("fib(5) = {fibonacci(5)}");
    print("fib(7) = {fibonacci(7)}");
    
    print("=== Loop Test ===");
    var sum = 0;
    for (var i = 1; i <= 5; i = i + 1) {
        sum = sum + i;
    }
    print("Sum 1-5 = {sum}");
}

main();
