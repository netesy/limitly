// Simple test for runtime structures integration
// Tests basic list, dict, and tuple operations with RegisterVM

print("=== Simple Runtime Test ===");

// Test basic list operations
print("Testing basic list operations...");

// Create list
let lst = [];
print("Created empty list");

// Append elements
lst.append(42);
lst.append("hello");
lst.append(3.14);

print("List length:", lst.len());
print("Element 0:", lst[0]);
print("Element 1:", lst[1]);
print("Element 2:", lst[2]);

// Test basic dictionary operations
print("\nTesting basic dictionary operations...");

// Create dictionary
let d = {};
print("Created empty dictionary");

// Set values
d["name"] = "test";
d["count"] = 5;
d["value"] = 2.5;

print("Dictionary values:");
print("  name:", d["name"]);
print("  count:", d["count"]);
print("  value:", d["value"]);

// Test basic tuple operations
print("\nTesting basic tuple operations...");

// Create tuple
let t = (1, "two", 3.0);
print("Created tuple with 3 elements");

print("Tuple elements:");
print("  [0]:", t[0]);
print("  [1]:", t[1]);
print("  [2]:", t[2]);

print("\n=== Test Complete ===");
print("✅ Lists working");
print("✅ Dicts working");
print("✅ Tuples working");
