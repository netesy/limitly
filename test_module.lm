// test_module.lm - Test the module system

import math_module as math;

fn main() {
    var result1 = math.add(5, 3);
    print("5 + 3 = {result1}");
    
    var result2 = math.multiply(4, 7);
    print("4 * 7 = {result2}");
    
    var result3 = math.square(6);
    print("6 squared = {result3}");
}

main();
