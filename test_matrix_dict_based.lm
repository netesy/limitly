// Test matrices using dictionaries
print("=== Matrix Tests Using Dictionaries ===");

// Test 1: 2D Matrix using nested dicts
print("\n--- Test 1: 2D Matrix with Dicts ---");
var matrix_2d = {
    "0": {"0": 1, "1": 2, "2": 3},
    "1": {"0": 4, "1": 5, "2": 6},
    "2": {"0": 7, "1": 8, "2": 9}
};

print("2D Matrix (3x3) created using dicts");

// Access elements
var row0 = matrix_2d["0"];
var row1 = matrix_2d["1"];
var row2 = matrix_2d["2"];

print("Row 0: {row0}");
print("Row 1: {row1}");
print("Row 2: {row2}");

// Test 2: Access specific elements
print("\n--- Test 2: Element Access ---");
var elem_0_0 = row0["0"];
var elem_1_1 = row1["1"];
var elem_2_2 = row2["2"];

print("Element [0][0]: {elem_0_0}");
print("Element [1][1]: {elem_1_1}");
print("Element [2][2]: {elem_2_2}");

// Test 3: 3D Matrix using nested dicts
print("\n--- Test 3: 3D Matrix with Dicts ---");
var matrix_3d = {
    "0": {
        "0": {"0": 1, "1": 2},
        "1": {"0": 3, "1": 4}
    },
    "1": {
        "0": {"0": 5, "1": 6},
        "1": {"0": 7, "1": 8}
    }
};

print("3D Matrix (2x2x2) created using dicts");

// Access 3D elements
var layer0 = matrix_3d["0"];
var row0_layer0 = layer0["0"];
var elem_0_0_0 = row0_layer0["0"];
var elem_0_0_1 = row0_layer0["1"];

print("Element [0][0][0]: {elem_0_0_0}");
print("Element [0][0][1]: {elem_0_0_1}");

var layer1 = matrix_3d["1"];
var row1_layer1 = layer1["1"];
var elem_1_1_0 = row1_layer1["0"];
var elem_1_1_1 = row1_layer1["1"];

print("Element [1][1][0]: {elem_1_1_0}");
print("Element [1][1][1]: {elem_1_1_1}");

// Test 4: Large 2D matrix
print("\n--- Test 4: Large 2D Matrix (5x5) ---");
var large_matrix = {
    "0": {"0": 1, "1": 2, "2": 3, "3": 4, "4": 5},
    "1": {"0": 6, "1": 7, "2": 8, "3": 9, "4": 10},
    "2": {"0": 11, "1": 12, "2": 13, "3": 14, "4": 15},
    "3": {"0": 16, "1": 17, "2": 18, "3": 19, "4": 20},
    "4": {"0": 21, "1": 22, "2": 23, "3": 24, "4": 25}
};

print("5x5 Matrix created");

// Access corners
var top_left = large_matrix["0"]["0"];
var top_right = large_matrix["0"]["4"];
var bottom_left = large_matrix["4"]["0"];
var bottom_right = large_matrix["4"]["4"];

print("Top-left [0][0]: {top_left}");
print("Top-right [0][4]: {top_right}");
print("Bottom-left [4][0]: {bottom_left}");
print("Bottom-right [4][4]: {bottom_right}");

// Test 5: Center element
print("\n--- Test 5: Center Element ---");
var center = large_matrix["2"]["2"];
print("Center [2][2]: {center}");
print("Expected: 13");

print("\n=== Dictionary-Based Matrix Tests Complete ===");
