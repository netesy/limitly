// Test basic functionality
print("=== Regression Tests ===");

// Variables
var x = 10;
var y = 5;
print("Variables work");

// If statements
if (x > y) {
    print("If statement works");
}

// While loop
var i = 0;
while (i < 2) {
    print("While loop works");
    i = i + 1;
}

// For loop
for (var j = 0; j < 2; j = j + 1) {
    print("For loop works");
}

print("=== All tests passed ===");
