import std.gfx.context as gfx_context;
import std.ui.types as ui_types;
import std.ui.context as ui_context;
import std.ui.builder as builder;

// Test helper function
fn assert_equal(actual: int, expected: int, test_name: str): int {
    if (actual == expected) {
        print("[PASS] {test_name}");
        return 1;
    } else {
        print("[FAIL] {test_name} - Expected: {expected}, Got: {actual}");
        return 0;
    }
}

fn assert_not_equal(actual: int, unexpected: int, test_name: str): int {
    if (actual != unexpected) {
        print("[PASS] {test_name}");
        return 1;
    } else {
        print("[FAIL] {test_name} - Should not be: {unexpected}");
        return 0;
    }
}

fn assert_equal_float(actual: float, expected: float, tolerance: float, test_name: str): int {
    var diff: float = actual - expected;
    if (diff < 0) {
        diff = -diff;
    }
    if (diff < tolerance) {
        print("[PASS] {test_name}");
        return 1;
    } else {
        print("[FAIL] {test_name} - Expected: {expected}, Got: {actual}");
        return 0;
    }
}

// FFI Tests
fn test_ffi_memory_allocation(): int {
    var passed: int = 0;
    
    // Test allocation
    var ptr: int = ffi.ffi_alloc(1024);
    passed = passed + assert_not_equal(ptr, 0, "FFI: Memory allocation");
    
    // Test deallocation
    if (ptr != 0) {
        ffi.ffi_free(ptr);
        passed = passed + assert_equal(1, 1, "FFI: Memory deallocation");
    }
    
    return passed;
}

fn test_ffi_pointer_arithmetic(): int {
    var passed: int = 0;
    
    var ptr: int = ffi.ffi_alloc(256);
    
    // Test pointer addition
    var ptr_plus: int = ffi.ptr_add(ptr, 64);
    passed = passed + assert_equal(ffi.ptr_diff(ptr_plus, ptr), 64, "FFI: Pointer addition");
    
    // Test pointer subtraction
    var ptr_minus: int = ffi.ptr_sub(ptr_plus, 32);
    passed = passed + assert_equal(ffi.ptr_diff(ptr_plus, ptr_minus), 32, "FFI: Pointer subtraction");
    
    // Test pointer difference
    var diff: int = ffi.ptr_diff(ptr_plus, ptr);
    passed = passed + assert_equal(diff, 64, "FFI: Pointer difference");
    
    // Test pointer alignment
    var aligned: int = ffi.ptr_align(ptr, 16);
    var is_aligned: int = ffi.ptr_is_aligned(aligned, 16);
    passed = passed + assert_equal(is_aligned, 1, "FFI: Pointer alignment");
    
    ffi.ffi_free(ptr);
    
    return passed;
}

fn test_ffi_memory_operations(): int {
    var passed: int = 0;
    
    var src: int = ffi.ffi_alloc(128);
    var dst: int = ffi.ffi_alloc(128);
    
    // Test memset
    ffi.ffi_memset(src, 42, 64);
    var val: int = ffi.ffi_load_int8(src);
    passed = passed + assert_equal(val, 42, "FFI: Memory set");
    
    // Test memcpy
    ffi.ffi_memcpy(dst, src, 64);
    var val2: int = ffi.ffi_load_int8(dst);
    passed = passed + assert_equal(val2, 42, "FFI: Memory copy");
    
    // Test memcmp
    var cmp: int = ffi.ffi_memcmp(src, dst, 64);
    passed = passed + assert_equal(cmp, 0, "FFI: Memory compare");
    
    ffi.ffi_free(src);
    ffi.ffi_free(dst);
    
    return passed;
}

fn test_ffi_load_store_operations(): int {
    var passed: int = 0;
    
    var ptr: int = ffi.ffi_alloc(64);
    
    // Test int32 store/load
    ffi.ffi_store_int32(ptr, 12345);
    var loaded_int32: int = ffi.ffi_load_int32(ptr);
    passed = passed + assert_equal(loaded_int32, 12345, "FFI: Int32 store/load");
    
    // Test int64 store/load
    ffi.ffi_store_int64(ptr + 8, 9876543210);
    var loaded_int64: int = ffi.ffi_load_int64(ptr + 8);
    passed = passed + assert_equal(loaded_int64, 9876543210, "FFI: Int64 store/load");
    
    // Test float store/load
    ffi.ffi_store_float(ptr + 16, 3.14159);
    var loaded_float: float = ffi.ffi_load_float(ptr + 16);
    passed = passed + assert_equal_float(loaded_float, 3.14159, 0.0001, "FFI: Float store/load");
    
    // Test double store/load
    ffi.ffi_store_double(ptr + 24, 2.71828);
    var loaded_double: float = ffi.ffi_load_double(ptr + 24);
    passed = passed + assert_equal_float(loaded_double, 2.71828, 0.0001, "FFI: Double store/load");
    
    // Test pointer store/load
    ffi.ffi_store_ptr(ptr + 32, ptr);
    var loaded_ptr: int = ffi.ffi_load_ptr(ptr + 32);
    passed = passed + assert_equal(loaded_ptr, ptr, "FFI: Pointer store/load");
    
    ffi.ffi_free(ptr);
    
    return passed;
}

