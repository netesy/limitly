// Match Statement Tests - Comprehensive Coverage
// Tests literal patterns, enum patterns, frame patterns, variable patterns, and wildcards

print("=== Match Statement Tests ===");

// Test 1: Literal integer patterns
print("\n--- Test 1: Literal Integer Patterns ---");
var x: int = 10;

match (x) {
    5 => { print("x is five"); },
    10 => { print("x is ten"); },
    _ => { print("x is something else"); }
}

// Test 2: Variable binding patterns
print("\n--- Test 2: Variable Binding Patterns ---");
var value = 42;

match (value) {
    n => { print("The value is: {n}"); }
}

// Test 3: Enum pattern matching
print("\n--- Test 3: Enum Pattern Matching ---");
enum Status {
    Active,
    Inactive,
    Pending
}

var status = Status.Active;

match (status) {
    Status.Active => { print("Status is Active"); },
    Status.Inactive => { print("Status is Inactive"); },
    Status.Pending => { print("Status is Pending"); },
    _ => { print("Unknown status"); }
}

// Test 4: Enum with associated values
print("\n--- Test 4: Enum with Associated Values ---");
enum Result {
    Success(str),
    Error(str),
    Pending
}

var result1 = Result.Success("Operation completed");
var result2 = Result.Error("Something went wrong");

fn describeResult(r: Result) {
    match (r) {
        Result.Success(msg) => { print("Success: {msg}"); },
        Result.Error(msg) => { print("Error Result: {msg}"); },
        Result.Pending => { print("Operation is pending"); }
    }
}

describeResult(result1);
describeResult(result2);

// Test 5: Frame pattern matching
print("\n--- Test 5: Frame Pattern Matching ---");
frame Point {
    pub var x: float;
    pub var y: float;
}

var p = Point(x=10.0, y=20.0);

match (p) {
    point => { print("Point at ({point.x}, {point.y})"); }
}

// Test 6: Wildcard patterns
print("\n--- Test 6: Wildcard Patterns ---");
var anything = "hello";

match (anything) {
    _ => { print("Matched anything: {anything}"); }
}

// Test 7: Nested match statements
print("\n--- Test 7: Nested Match Statements ---");
enum Color {
    Red,
    Green,
    Blue
}

enum Shape {
    Circle(Color),
    Square(Color)
}

var shape = Shape.Circle(Color.Red);

match (shape) {
    Shape.Circle(color) => {
        match (color) {
            Color.Red => { print("Red circle"); },
            Color.Green => { print("Green circle"); },
            Color.Blue => { print("Blue circle"); },
            _ => { print("Unknown color circle"); }
        }
    },
    Shape.Square(color) => {
        match (color) {
            Color.Red => { print("Red square"); },
            Color.Green => { print("Green square"); },
            Color.Blue => { print("Blue square"); },
            _ => { print("Unknown color square"); }
        }
    }
}

// Test 8: Match in function with return
print("\n--- Test 8: Match with Return Values ---");
fn getDayName(dayNum: int): str {
    match (dayNum) {
        1 => { return "Monday"; },
        2 => { return "Tuesday"; },
        3 => { return "Wednesday"; },
        4 => { return "Thursday"; },
        5 => { return "Friday"; },
        6 => { return "Saturday"; },
        7 => { return "Sunday"; },
        _ => { return "Invalid day"; }
    }
}

var day1 = getDayName(1);
var day5 = getDayName(5);
var day10 = getDayName(10);

assert(day1 == "Monday", "Day 1 should be Monday");
assert(day5 == "Friday", "Day 5 should be Friday");
assert(day10 == "Invalid day", "Day 10 should be Invalid day");

print("Day 1: {day1}");
print("Day 5: {day5}");
print("Day 10: {day10}");

// Test 9: Match with multiple cases
print("\n--- Test 9: Multiple Match Cases ---");
enum Message {
    Quit,
    Move(int, int),
    Write(str)
}

fn processMessage(msg: Message): str {
    match (msg) {
        Message.Quit => { return "Quitting application..."; },
        Message.Move(x, y) => { return "Moving to position ({x}, {y})"; },
        Message.Write(text) => { return "Writing message: {text}"; }
    }
}

var msg1 = processMessage(Message.Quit);
var msg2 = processMessage(Message.Move(10, 20));
var msg3 = processMessage(Message.Write("Hello, World!"));

assert(msg1 == "Quitting application...", "Quit message failed");
assert(msg2 == "Moving to position (10, 20)", "Move message failed");
assert(msg3 == "Writing message: Hello, World!", "Write message failed");

print("Message 1: {msg1}");
print("Message 2: {msg2}");
print("Message 3: {msg3}");

// Test 10: Guard clauses
print("\n--- Test 10: Guard Clauses ---");
fn getGuard(ans: int): str {
match(ans) {
    x where x > 10 => { return "greater than 10"; },
    x where x < 10 => { return "less than 10"; },
    x => { return "exactly 10"; }
}
}
var result10 =  getGuard(10);
assert(result10 == "exactly 10", "Guard clause test for 10 failed");

var result15 = getGuard(15);

assert(result15 == "greater than 10", "Guard clause test for 15 failed");

var result5 = getGuard(5);

assert(result5 == "less than 10", "Guard clause test for 5 failed");

print("Value 10: {result10}");
print("Value 15: {result15}");
print("Value 5: {result5}");

print("\n=== Match Statement Tests Complete ===");
