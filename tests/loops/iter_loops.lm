// Test iter loops
print("=== Iter Loop Tests ===");

// Basic range iteration
print("Basic range (1 to 5):");
var basicCount = 0;
var basicSum = 0;
iter (var i in 1..6) {
    print("i = {i}");
    basicCount += 1;
    basicSum += i;
}
assert(basicCount == 5, "Basic iter should iterate 5 times (1-5)");
assert(basicSum == 15, "Sum of 1+2+3+4+5 should be 15");

// Range with different bounds
print("Range (0 to 3):");
var rangeCount = 0;
var rangeSum = 0;
iter (var x in 0..4) {
    print("x = {x}");
    rangeCount += 1;
    rangeSum += x;
}
assert(rangeCount == 4, "Range iter should iterate 4 times (0-3)");
assert(rangeSum == 6, "Sum of 0+1+2+3 should be 6");

// Nested iter loops
print("Nested iter loops:");
var nestedCount = 0;
var totalPairs = 0;
iter (var x in 1..3) {
    print("Outer {x}");
    iter (var j in 10..13) {
        print("({x}, {j})");
        nestedCount += 1;
        totalPairs += x * 100 + j;
    }
}
assert(nestedCount == 6, "Nested iter should iterate 6 times (2x3)");

// Mixed nested loops (for + iter)
print("Mixed loops (for outer, iter inner):");
var mixedCount = 0;
var mixedSum = 0;
for (var i = 0; i < 4; i += 2) {
    iter (var j in 5..8) {
        print("for-iter: ({i}, {j})");
        mixedCount += 1;
        mixedSum += i + j;
    }
}
assert(mixedCount == 6, "Mixed for-iter should iterate 6 times (2x3)");

// Mixed nested loops (iter + for)
print("Mixed loops (iter outer, for inner):");
var mixed2Count = 0;
var mixed2Sum = 0;
iter (var i in 1..3) {
    for (var j = 0; j < 5; j += 2) {
        print("iter-for: ({i}, {j})");
        mixed2Count += 1;
        mixed2Sum += i * j;
    }
}
assert(mixed2Count == 6, "Mixed iter-for should iterate 6 times (2x3)");

// Range with expressions
var start = 2;
var end = 5;
print("Range with variables ({start} to {end}):");
var varCount = 0;
var varSum = 0;
iter (var k in start..end) {
    print("k = {k}");
    varCount += 1;
    varSum += k;
}
assert(varCount == 3, "Variable range should iterate 3 times (2-4)");
assert(varSum == 9, "Sum of 2+3+4 should be 9");

// Iter loop with break and continue
print("Iter loop with break/continue:");
var breakCount = 0;
var breakSum = 0;
iter (var i in 0..10) {
    if (i == 3) {
        continue;
    }
    if (i == 7) {
        break;
    }
    print("Iter value: {i}");
    breakCount += 1;
    breakSum += i;
}
assert(breakCount == 6, "Iter loop should execute 6 times (skip 3, break at 7)");
assert(breakSum == 18, "Sum should be 0+1+2+4+5+6 = 18");

// Iter loop over calculated range
print("Iter over calculated range:");
var base = 10;
var offset = 3;
var calcCount = 0;
var calcSum = 0;
iter (var i in base..(base + offset)) {
    print("Calculated: {i}");
    calcCount += 1;
    calcSum += i;
}
assert(calcCount == 3, "Calculated range should iterate 3 times");
assert(calcSum == 33, "Sum of 10+11+12 should be 33");

print("=== Iter Loop Tests Complete ===");