// Test parallel blocks 
print("=== Parallel Block Tests ===");

// ==========================================
//  Simple parallel block (CPU bound)
// ==========================================
var counter = 0;
var results: array[1000] = 0;

parallel {
    // Direct SharedCell operations - no task statements
    iter(i in 0..999) {
        results[i] = i * 2;  // SharedCell access to results array
        counter = counter + 1;  // SharedCell access to counter
    }
}

print("Parallel processing complete");
print("Counter: {counter}");
print("First result: {results[0]}");
print("Last result: {results[999]}");

// ==========================================
//  Parallel block with parameters
// ==========================================
var matrix: array[100][100] = 0;

parallel(cores=4, timeout=30s, on_error=Stop) {
    // Direct SharedCell operations - no task statements
    iter(i in 0..99) {
        iter(j in 0..99) {
            matrix[i][j] = i * 100 + j;  // SharedCell access to matrix
        }
    }
}

print("Matrix processing complete");
print("Matrix[0][0]: {matrix[0][0]}");
print("Matrix[99][99]: {matrix[99][99]}");

// ==========================================
//  Parallel block with SharedCell operations
// ==========================================
var shared_sum = 0;

parallel(cores=Auto, timeout=60s, grace=1s, on_error=Continue) {
    // Direct SharedCell operations
    iter(i in 1..1000) {
        shared_sum = shared_sum + i;  // Atomic SharedCell add
    }
}

print("Sum calculation complete");
print("Shared sum: {shared_sum}");