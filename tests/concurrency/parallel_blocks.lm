// Test parallel blocks with iter-based execution
print("=== Parallel Block Tests ===");

// ==========================================
//  Simple parallel block with iter
// ==========================================
var counter = 0;
var results = channel();

parallel(cores=4) {
    iter(i in 0..99) {
        results.send(i * 2);
        counter = counter + 1;
    }
}

print("Parallel processing complete");
print("Counter: {counter}");

// Collect results
var result_count = 0;
var first_result = 0;
var last_result = 0;

iter (result in results) {
    if (result_count == 0) {
        first_result = result;
    }
    last_result = result;
    result_count = result_count + 1;
}

print("Results collected: {result_count}");
print("First result: {first_result}");
print("Last result: {last_result}");

assert(counter == 100, "Parallel block should execute 100 iterations");
assert(result_count == 100, "All results should be collected");
assert(first_result == 0, "First result should be 0*2 = 0");
assert(last_result == 198, "Last result should be 99*2 = 198");

// ==========================================
//  Parallel block with multiple cores
// ==========================================
var results2 = channel();
var task_count = 0;

parallel(cores=8) {
    iter(i in 0..199) {
        results2.send(i * 3);
        task_count = task_count + 1;
    }
}

print("Second parallel block complete");
print("Tasks executed: {task_count}");

// Collect and verify results
var sum = 0;
iter (result in results2) {
    sum = sum + result;
}

print("Sum of results: {sum}");

assert(task_count == 200, "Second parallel block should execute 200 iterations");
assert(sum == 59700, "Sum should be sum of i*3 for i=0..199 = 3*sum(0..199) = 3*19900 = 59700");

// ==========================================
//  Parallel block with smaller range
// ==========================================
var results3 = channel();

parallel(cores=2) {
    iter(i in 0..9) {
        results3.send(i * 10);
    }
}

print("Third parallel block complete");

// Display results
var result_count3 = 0;
iter (result in results3) {
    print("  Result: {result}");
    result_count3 = result_count3 + 1;
}

assert(result_count3 == 10, "Third parallel block should execute 10 iterations");
