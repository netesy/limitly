print(" === Concurrent Block Tests === ");

// // ==========================================
// //  Basic concurrent execution (tasks only)
// // ==========================================
var output_results = channel();

concurrent(ch = output_results,
cores = Auto,
on_error = Stop,
timeout = 20s,
grace = 500ms) {

    task(i in 1..3) {
        print("Concurrent task {i} running");
        //sleep(3.00);
        output_results.send("Task {i} completed");
        }
    } // auto - close output_results

    iter (result in output_results) {
        print("Received result: {result}");
    }

    print("Concurrent block finished");

    // ==========================================
    //  Stream processing with workers
    // ==========================================
    var stream_out = channel();

    // // input source is a stream, NOT a channel owned by concurrent
    var events = ["info1", "info2", "info3"];// iterable → stream

    concurrent(ch = stream_out,
    cores = 4,
    timeout = 15s,
    grace = 500ms) {

        worker(event from events) {
            print("Processing event: {event}");
            stream_out.send("Handled {event}");
            }
        } // auto - close stream_out

        iter (msg in stream_out) {
            print("Result: {msg}");
        }

        // ==========================================
        //  Multiple workers, same stream input
        // ==========================================
        var results = channel();
        var jobs = channel();// simple channel instead of jobStream

        // Use iter to seed the jobs channel
        var job_items = ["job1", "job2", "job3"];

        iter (item in job_items) {
            jobs.send(item);
        }
        jobs.close();

        concurrent(ch = results, cores = 2, timeout = 10s) {

            worker(item from jobs) {
                results.send("Processed: {item}");
                }
            } // auto - close results

            iter (result in results) {
                print("Final result: {result}");
            }

            // ==========================================
            //  Tasks seeding a worker stream
            // ==========================================
            print(" === Tasks seeding a worker stream (seed via iter) === ");

            var seeded_results = channel();
            var seed_stream = channel();// external stream

            // Seed the stream using iter outside the concurrent block
            var seeds = ["bootstrap - 1", "bootstrap - 2"];

            iter (item in seeds) {
                seed_stream.send(item);
            }
            seed_stream.close();// close so worker knows no more items are coming

            // Worker consumes the pre-seeded stream
            concurrent(ch = seeded_results) {
                worker(x from seed_stream) {
                    seeded_results.send("Handled: {x}");
                    }
                } // auto - close seeded_results

                iter (msg in seeded_results) {
                    print("Seeded result: {msg}");
                }
