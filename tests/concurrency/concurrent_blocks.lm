print(" === Concurrent Block Tests === ");

// ==========================================
//  Basic concurrent execution (tasks only)
// ==========================================
var output_results = channel();

concurrent(ch = output_results, cores = 2) {
    task(i in 1..3) {
        print("Concurrent task {i} running");
        output_results.send("Task {i} completed");
        }
    }

    iter (result in output_results) {
        print("Received result: {result}");
    }

    print("Concurrent block finished");

    // ==========================================
    //  Multiple workers, same stream input
    // ==========================================
    var results = channel();
    var jobs = channel();

    // Seed the jobs channel
    jobs.send("job1");
    jobs.send("job2");
    jobs.send("job3");
    jobs.close();

    concurrent(ch = results, cores = 2) {
        worker(item from jobs) {
            results.send("Processed: {item}");
            }
        }

        iter (result in results) {
            print("Final result: {result}");
        }

        // ==========================================
        //  Tasks seeding a worker stream
        // ==========================================
        print(" === Tasks seeding a worker stream === ");

        var seeded_results = channel();
        var seed_stream = channel();

        // Seed the stream
        seed_stream.send("bootstrap - 1");
        seed_stream.send("bootstrap - 2");
        seed_stream.close();

        // Worker consumes the pre-seeded stream
        concurrent(ch = seeded_results) {
            worker(x from seed_stream) {
                seeded_results.send("Handled: {x}");
                }
            }

            iter (msg in seeded_results) {
                print("Seeded result: {msg}");
            }
            // ==========================================
            //  Tasks seeding a worker stream
            // ==========================================
            print(" === Tasks seeding a worker stream === ");

            var seeded_results = channel();
            var seed_stream = channel();

            // Seed the stream
            seed_stream.send("bootstrap - 1");
            seed_stream.send("bootstrap - 2");
            seed_stream.close();

            // Worker consumes the pre-seeded stream
            concurrent(ch = seeded_results) {
                worker(x from seed_stream) {
                    seeded_results.send("Handled: {x}");
                    }
                }

                iter (msg in seeded_results) {
                    print("Seeded result: {msg}");
                }
