print("=== Concurrent Block Tests ===");

// ==========================================
//  Basic concurrent execution (stream mode)
// ==========================================
// concurrent = I/O-bound, uses channels only (no SharedCell)
var input_events = channel();
var output_results = channel();

concurrent(ch=input_events, cores=Auto, on_error=Stop,
           timeout=20s, grace=500ms) {
    task(i in 1..3) {
        print("Concurrent task {i} running");
        sleep(randint(1, 3));
        output_results.send("Task {i} completed");  // Channel communication only
    }
} // auto-close input_events when done

// Feed events to concurrent block
input_events.send("event1");
input_events.send("event2");
input_events.send("event3");

iter (result in output_results) {
    print("Received result: {result}");
}
print("Concurrent block finished");


// ==========================================
//  Stream processing with workers
// ==========================================
var stream_in = channel();
var stream_out = channel();

concurrent(ch=stream_in, cores=4, timeout=15s, grace=500ms) {
    worker(event) {
        print("Processing event: {event}");
        stream_out.send("Handled {event}");  // Channel communication only
    }
} // auto-close stream_in

// Feed events to stream
stream_in.send("data1");
stream_in.send("data2");
stream_in.send("data3");

iter (msg in stream_out) {
    print("Result: {msg}");
}


// ==========================================
//  Concurrent block with channel parameter assignment
// ==========================================
var main_channel = channel();

concurrent(ch=main_channel, cores=2, timeout=10s) {
    worker(item) {
        processed = "Processed: {item}";
        main_channel.send(processed);  // Channel communication only
    }
}

// Feed items to workers
main_channel.send("item1");
main_channel.send("item2");

iter (result in main_channel) {
    print("Final result: {result}");
}


// ==========================================
//  Simple concurrent block with no parameters
// ==========================================
var simple_channel = channel();

concurrent {
    worker(data) {
        simple_channel.send("Worker processed: {data}");  // Channel communication only
    }
}

simple_channel.send("test_data");

iter (result in simple_channel) {
    print("Simple result: {result}");
}
