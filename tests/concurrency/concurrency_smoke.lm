// Concurrency smoke test - exercises concurrent blocks with channels
print("=== Concurrency Smoke Test ===");

// Channel for communication
var results = channel();

print("Testing concurrent task iteration");

// Fixed iteration block - using channels only (no SharedCell)
concurrent(ch=results, cores=2, on_error=Stop) {
    task(i in 1..4) {
        print("Task {i} running");
        results.send("Task {i} completed");  // Channel communication only
    }
}

// Collect results
var task_count = 0;
iter (result in results) {
    print("Received: {result}");
    task_count = task_count + 1;
}

assert(task_count == 4, "Should receive 4 results");
print("Task tests completed");
print("Final task count: {task_count}");

// Test worker statements
print("=== Testing Worker Statements ===");

var worker_results = channel();

concurrent(ch=worker_results, cores=2) {
    worker(datas) {
        processed = "Worker processed: {datas}";
        worker_results.send(processed);  // Channel communication only
    }
}

// Feed data to workers
worker_results.send("data1");
worker_results.send("data2");

var worker_count = 0;
iter (result in worker_results) {
    print("Worker result: {result}");
    worker_count = worker_count + 1;
}

assert(worker_count == 2, "Should receive 2 worker results");
print("Worker tests completed");
print("Final worker count: {worker_count}");

