import std.ffi as ffi

fn main() {
    print("=== Limitly FFI Validity Test ===");
    var ptr: int = ffi.alloc(1024);
    if (ptr != 0) {
        print("[PASS] ffi.alloc should return non-zero pointer");
    } else {
        print("[FAIL] ffi.alloc should return non-zero pointer - Got: {ptr}");
    }
}

main();
