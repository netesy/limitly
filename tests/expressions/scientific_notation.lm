// Test scientific notation parsing and evaluation
print("=== Scientific Notation Tests ===");

// Test basic scientific notation
var small: f64 = 1.23e-10;
var large: f64 = 4.56e+15;
var negative: f64 = 7.89e-5;

print("Scientific notation test:");
print("Small:", small);
print("Large:", large);
print("Negative:", negative);

assert(small == 1.23e-10, "Small scientific notation should parse correctly");
assert(large == 4.56e+15, "Large scientific notation should parse correctly");
assert(negative == 7.89e-5, "Negative scientific notation should parse correctly");

// Test with capital E
var capitalE: f64 = 2.5E+8;
var capitalENeg: f64 = 3.14E-3;

print("Capital E notation:");
print("Capital E positive:", capitalE);
print("Capital E negative:", capitalENeg);

assert(capitalE == 2.5e+8, "Capital E positive should work");
assert(capitalENeg == 3.14e-3, "Capital E negative should work");

// Test integer scientific notation (should be treated as float)
var intScientific: f64 = 5e10;
var intScientificNeg: f64 = 2e-6;

print("Integer scientific notation:");
print("Int scientific:", intScientific);
print("Int scientific negative:", intScientificNeg);

assert(intScientific == 5e10, "Integer scientific notation should work");
assert(intScientificNeg == 2e-6, "Integer scientific notation negative should work");

// Test edge cases
var zero: f64 = 0e0;
var one: f64 = 1e0;

print("Edge cases:");
print("Zero:", zero);
print("One:", one);

assert(zero == 0.0, "Zero scientific notation should be 0");
assert(one == 1.0, "One scientific notation should be 1");

// Test in expressions
var result: f64 = 1.5e3 + 2.5e2;
print("Expression result:", result);

assert(result == 1500.0 + 250.0, "Scientific notation in expressions should work");
assert(result == 1750.0, "1.5e3 + 2.5e2 should equal 1750.0");

// Test arithmetic with scientific notation
var multiply: f64 = 2e3 * 3e2;
var divide: f64 = 6e6 / 2e3;
var subtract: f64 = 5e4 - 1e4;

print("Arithmetic operations:");
print("Multiply: 2e3 * 3e2 = {multiply}");
print("Divide: 6e6 / 2e3 = {divide}");
print("Subtract: 5e4 - 1e4 = {subtract}");

assert(multiply == 600000.0, "2e3 * 3e2 should equal 6e5");
assert(divide == 3000.0, "6e6 / 2e3 should equal 3e3");
assert(subtract == 40000.0, "5e4 - 1e4 should equal 4e4");

print("=== Scientific Notation Tests Complete ===");