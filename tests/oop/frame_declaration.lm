// Test frame declaration parsing
// This tests basic frame syntax, fields, methods, and trait implementation

// Simple frame with fields and methods
frame Person {
    pub name: str;
    pub age: int;
    prot email: str;

    pub fn greet(): str {
        return "Hello, {this.name}";
    }

    pub fn birthday() {
        this.age = this.age + 1;
    }
}

// Frame with init() method
frame Point {
    pub x: int;
    pub y: int;

    pub init(px: int, py: int) {
        this.x = px;
        this.y = py;
    }

    pub fn distance(): int {
        return this.x + this.y;
    }
}

// Frame with deinit() method
frame Resource {
    pub id: int;

    pub init(resource_id: int) {
        this.id = resource_id;
    }

    pub deinit() {
        print("Cleaning up resource");
    }
}

// Frame with default field values
frame Config {
    pub debug: bool = false;
    pub timeout: int = 30;
    pub name: str = "default";
}

// Frame with visibility modifiers
frame BankAccount {
    pub accountNumber: str;
    prot balance: int;

    pub fn deposit(amount: int) {
        this.balance = this.balance + amount;
    }

    prot fn calculateInterest(): int {
        return this.balance / 100;
    }
}

// Frame with multiple methods
frame Calculator {
    pub fn add(a: int, b: int): int {
        return a + b;
    }

    pub fn subtract(a: int, b: int): int {
        return a - b;
    }

    pub fn multiply(a: int, b: int): int {
        return a * b;
    }
}

// Test instantiation and method calls
var person = Person(name="Alice", age=30, email="alice@example.com");
print(person.greet());

var point = Point(10, 20);
print(point.distance());

var config = Config();
print(config.debug);
print(config.timeout);

var calc = Calculator();
print(calc.add(5, 3));

var res = Resource(123);
