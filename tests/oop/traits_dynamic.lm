// tests/oop/traits_dynamic.lm
trait Shape {
    fn area(): int;
    fn name(): str;
}

frame Circle : Shape {
    var radius: int;
    
    pub fn area(): int {
        return 3 * self.radius * self.radius; // Simplified PI
    }
    
    pub fn name(): str {
        return "Circle";
    }
}

frame Square : Shape {
    var side: int;
    
    pub fn area(): int {
        return self.side * self.side;
    }
    
    pub fn name(): str {
        return "Square";
    }
}

fn print_shape_info(s: Shape) {
    print(s.name());
    print(s.area());
}

fn main() {
    var c = Circle(radius=5);
    var s = Square(side=10);
    
    // Dynamic dispatch via trait objects
    print_shape_info(c);
    print_shape_info(s);
    
    // Assert trait functionality
    assert(c.name() == "Circle", "Trait method should work for Circle");
    assert(c.area() == 75, "Circle area should be 3*5*5 = 75");
    assert(s.name() == "Square", "Trait method should work for Square");
    assert(s.area() == 100, "Square area should be 10*10 = 100");
}

main();