// Test basic frame declaration parsing

// Simple frame with fields
frame Point {
    pub x: int;
    pub y: int;
}

// Frame with methods
frame Counter {
    prot count: int = 0;
    
    pub fn increment() {
        this.count = this.count + 1;
    }
    
    pub fn get_count(): int {
        return this.count;
    }
}

// Frame with trait implementation
frame Logger : Printable {
    pub message: str;
    
    pub fn prints() {
        print(this.message);
    }
}

// Frame with init and deinit
frame Resource {
    prot handle: int;
    
    pub init(h: int) {
        this.handle = h;
        print("Resource initialized");
    }
    
    pub deinit() {
        print("Resource cleaned up");
    }
}

// Frame with multiple traits
frame DataStore : Readable, Writable {
    datas: str = "";
    
    pub fn read(): str {
        return this.datas;
    }
    
    pub fn write(value: str) {
        this.datas = value;
    }
}
}

print("Frame parsing test completed");
