frame Counter {
    pub count: int = 0

    pub init() {
        this.count = 0
    }

    pub add(n: int) {
        this.count += n
    }
}

pub fn main() {
    var c = Counter()
    
    parallel(cores=4) {
        c.add(1)
        c.add(1)
        c.add(1)
        c.add(1)
    }
    
    print("Final count: " + str(c.count))
}
