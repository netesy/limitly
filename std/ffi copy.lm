// Foreign Function Interface (FFI) Module
// Provides C ABI interoperability and native memory management

// Primitive type aliases mapping Limitly to C-equivalent widths
// All types are explicitly sized for cross-platform C ABI compatibility

// C integer types with explicit bit widths
type c_char = int;
type c_short = int;
type c_int = int;
type c_long = int;
type c_longlong = int;

// C unsigned integer types with explicit bit widths
type c_uchar = int;
type c_ushort = int;
type c_uint = int;
type c_ulong = int;
type c_ulonglong = int;

// C size types (platform-dependent, typically 64-bit on modern systems)
type c_size_t = int;
type c_ssize_t = int;
type c_ptrdiff_t = int;

// C floating-point types
type c_float = float;
type c_double = float;

// C pointer types represented as opaque integers
type pubptr = int;
type fnptr = int;

// C boolean type (0 = false, non-zero = true)
type c_bool = int;

// C void type (used for return type indicators)
type c_void = int;

// Alignment constants for 64-bit platforms
var ALIGNMENT_CHAR: int = 1;
var ALIGNMENT_SHORT: int = 2;
var ALIGNMENT_INT: int = 4;
var ALIGNMENT_LONG: int = 8;
var ALIGNMENT_LONGLONG: int = 8;
var ALIGNMENT_PTR: int = 8;
var ALIGNMENT_FLOAT: int = 4;
var ALIGNMENT_DOUBLE: int = 8;
var ALIGNMENT_MAX: int = 8;

// C ABI calling conventions
type CallingConvention = CDecl | StdCall | FastCall | ThisCall | VectorCall;

// Platform-specific ABI information
frame ABIInfo {
    var word_size: int;
    var stack_alignment: int;
    var pointer_size: int;
    var calling_convention: CallingConvention;
    var is_windows: bool;
    var is_linux: bool;
    var is_macos: bool;
}

// Get current platform ABI information
fn get_abi_info(): ABIInfo {
    var word_size_val: int = 8;
    var stack_align: int = 16;
    var ptr_size: int = 8;
    var is_win: int = 0;
    var is_lin: int = 0;
    var is_mac: int = 0;
    
    // Platform detection would be done via runtime intrinsics
    // For now, default to x86_64 SysV ABI
    return ABIInfo(
        word_size=word_size_val,
        stack_alignment=stack_align,
        pointer_size=ptr_size,
        calling_convention=CDecl,
        is_windows=(is_win != 0),
        is_linux=(is_lin != 0),
        is_macos=(is_mac != 0)
    );
}

// C struct layout with explicit padding for 64-bit alignment
frame CStructLayout {
    var size: int;
    var alignment: int;
    var fields: [int];
    var offsets: [int];
    var paddings: [int];
}

// Calculate struct layout with proper padding
fn calculate_struct_layout(field_sizes: [int], field_alignments: [int]): CStructLayout {
    var total_size: int = 0;
    var max_alignment: int = 1;
    var offsets: [int] = [];
    var paddings: [int] = [];
    
    var i: int = 0;
    while (i < len(field_sizes)) {
        var field_size: int = field_sizes[i];
        var field_align: int = field_alignments[i];
        
        if (field_align > max_alignment) {
            max_alignment = field_align;
        }
        
        // Calculate padding needed for alignment
        var current_offset: int = total_size;
        var aligned_offset: int = current_offset;
        var remainder: int = current_offset % field_align;
        
        if (remainder != 0) {
            aligned_offset = current_offset + (field_align - remainder);
        }
        
        var padding: int = aligned_offset - current_offset;
        
        // Add padding if needed
        if (padding > 0) {
            paddings = paddings + [padding];
        } else {
            paddings = paddings + [0];
        }
        
        offsets = offsets + [aligned_offset];
        total_size = aligned_offset + field_size;
        i = i + 1;
    }
    
    // Add tail padding to satisfy struct alignment
    var tail_padding: int = 0;
    var total_remainder: int = total_size % max_alignment;
    
    if (total_remainder != 0) {
        tail_padding = max_alignment - total_remainder;
        total_size = total_size + tail_padding;
    }
    
    return CStructLayout(
        size=total_size,
        alignment=max_alignment,
        fields=field_sizes,
        offsets=offsets,
        paddings=paddings
    );
}

