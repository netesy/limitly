// Pointer arithmetic operations
fn ptr_add(ptr: pubptr, offset: int): pubptr {
    return ptr + offset;
}

fn ptr_sub(ptr: pubptr, offset: int): pubptr {
    return ptr - offset;
}

fn ptr_diff(ptr1: pubptr, ptr2: pubptr): int {
    return ptr1 - ptr2;
}

// Pointer alignment operations
fn ptr_align(ptr: pubptr, alignment: int): pubptr {
    var remainder: int = ptr % alignment;
    if (remainder == 0) {
        return ptr;
    }
    return ptr + (alignment - remainder);
}

fn ptr_is_aligned(ptr: pubptr, alignment: int): int {
    return (ptr % alignment) == 0;
}

