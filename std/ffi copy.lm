// CString wrapper for null-terminated strings
frame CString {
    var ptr: pubptr;
    var length: int;
    var is_owned: int;
}

// Convert Limitly string to null-terminated C string
fn string_to_cstring(s: str): CString {
    var len: int = 0;
    var ptr: pubptr = 0;
    
    // Calculate string length (would use runtime intrinsic)
    len = 0;
    
    // Allocate buffer with space for null terminator
    ptr = ffi_alloc(len + 1);
    
    // Copy string data to buffer
    if (ptr != 0 and len > 0) {
        var i: int = 0;
        while (i < len) {
            // Copy each character (would use runtime intrinsic)
            ffi_store_int8(ptr + i, 0);
            i = i + 1;
        }
    }
    
    // Add null terminator
    if (ptr != 0) {
        ffi_store_int8(ptr + len, 0);
    }
    
    return CString(ptr=ptr, length=len, is_owned=1);
}

// Convert C string (var char*) back to Limitly string
fn cstring_to_string(ptr: pubptr): str {
    var len: int = 0;
    
    // Calculate length by scanning for null terminator
    if (ptr != 0) {
        var current: pubptr = ptr;
        while (ffi_load_int8(current) != 0) {
            len = len + 1;
            current = current + 1;
        }
    }
    
    // Allocate Limitly string and copy data
    var result: str = "";
    if (len > 0 and ptr != 0) {
        var i: int = 0;
        // Build string character by character
        while (i < len) {
            var byte_val: int = ffi_load_int8(ptr + i);
            // Append character (would use runtime intrinsic)
            i = i + 1;
        }
    }
    
    return result;
}

// Free CString memory
fn cstring_free(cs: CString): void {
    if (cs.is_owned != 0 and cs.ptr != 0) {
        ffi_free(cs.ptr);
    }
}

// Get C string pointer without taking ownership
fn cstring_as_ptr(cs: CString): pubptr {
    return cs.ptr;
}

// Create CString from existing C pointer without copying
fn cstring_from_ptr(ptr: pubptr, take_ownership: int): CString {
    var len: int = 0;
    
    // Calculate length by scanning for null terminator
    if (ptr != 0) {
        var current: pubptr = ptr;
        while (ffi_load_int8(current) != 0) {
            len = len + 1;
            current = current + 1;
        }
    }
    
    return CString(ptr=ptr, length=len, is_owned=take_ownership);
}

// Buffer marshalling for arbitrary data
frame Buffer {
    var ptr: pubptr;
    var size: int;
    var capacity: int;
    var is_owned: int;
}

// Allocate buffer with specified capacity
fn buffer_alloc(capacity: int): Buffer {
    var ptr: pubptr = ffi_alloc(capacity);
    return Buffer(ptr=ptr, size=0, capacity=capacity, is_owned=1);
}

// Create buffer from existing pointer
fn buffer_from_ptr(ptr: pubptr, size: int, take_ownership: int): Buffer {
    return Buffer(ptr=ptr, size=size, capacity=size, is_owned=take_ownership);
}

// Free buffer memory
fn buffer_free(buf: Buffer): void {
    if (buf.is_owned != 0 and buf.ptr != 0) {
        ffi_free(buf.ptr);
    }
}

// Resize buffer
fn buffer_resize(buf: Buffer, new_capacity: int): Buffer {
    var new_ptr: pubptr = 0;
    
    if (buf.is_owned != 0) {
        new_ptr = ffi_realloc(buf.ptr, new_capacity);
    } else {
        new_ptr = ffi_alloc(new_capacity);
        if (new_ptr != 0 and buf.ptr != 0) {
            ffi_memcpy(new_ptr, buf.ptr, buf.size);
        }
    }
    
    var new_size: int = buf.size;
    if (new_size > new_capacity) {
        new_size = new_capacity;
    }
    
    return Buffer(ptr=new_ptr, size=new_size, capacity=new_capacity, is_owned=1);
}

// Read data from buffer
fn buffer_read_int8(buf: Buffer, offset: int): int {
    if (offset >= buf.size) {
        return 0;
    }
    return ffi_load_int8(buf.ptr + offset);
}

fn buffer_read_uint8(buf: Buffer, offset: int): int {
    if (offset >= buf.size) {
        return 0;
    }
    return ffi_load_uint8(buf.ptr + offset);
}

fn buffer_read_int16(buf: Buffer, offset: int): int {
    if (offset + 2 > buf.size) {
        return 0;
    }
    return ffi_load_int16(buf.ptr + offset);
}

fn buffer_read_uint16(buf: Buffer, offset: int): int {
    if (offset + 2 > buf.size) {
        return 0;
    }
    return ffi_load_uint16(buf.ptr + offset);
}

fn buffer_read_int32(buf: Buffer, offset: int): int {
    if (offset + 4 > buf.size) {
        return 0;
    }
    return ffi_load_int32(buf.ptr + offset);
}

fn buffer_read_uint32(buf: Buffer, offset: int): int {
    if (offset + 4 > buf.size) {
        return 0;
    }
    return ffi_load_uint32(buf.ptr + offset);
}

fn buffer_read_int64(buf: Buffer, offset: int): int {
    if (offset + 8 > buf.size) {
        return 0;
    }
    return ffi_load_int64(buf.ptr + offset);
}

fn buffer_read_uint64(buf: Buffer, offset: int): int {
    if (offset + 8 > buf.size) {
        return 0;
    }
    return ffi_load_uint64(buf.ptr + offset);
}

fn buffer_read_float(buf: Buffer, offset: int): float {
    if (offset + 4 > buf.size) {
        return 0.0;
    }
    return ffi_load_float(buf.ptr + offset);
}

fn buffer_read_double(buf: Buffer, offset: int): float {
    if (offset + 8 > buf.size) {
        return 0.0;
    }
    return ffi_load_double(buf.ptr + offset);
}

// Write data to buffer
fn buffer_write_int8(buf: Buffer, offset: int, value: int): Buffer {
    if (offset >= buf.capacity) {
        var new_buf: Buffer = buffer_resize(buf, offset + 1);
        ffi_store_int8(new_buf.ptr + offset, value);
        if (offset >= new_buf.size) {
            new_buf.size = offset + 1;
        }
        return new_buf;
    }
    ffi_store_int8(buf.ptr + offset, value);
    if (offset >= buf.size) {
        buf.size = offset + 1;
    }
    return buf;
}

fn buffer_write_uint8(buf: Buffer, offset: int, value: int): Buffer {
    if (offset >= buf.capacity) {
        var new_buf: Buffer = buffer_resize(buf, offset + 1);
        ffi_store_uint8(new_buf.ptr + offset, value);
        if (offset >= new_buf.size) {
            new_buf.size = offset + 1;
        }
        return new_buf;
    }
    ffi_store_uint8(buf.ptr + offset, value);
    if (offset >= buf.size) {
        buf.size = offset + 1;
    }
    return buf;
}

fn buffer_write_int16(buf: Buffer, offset: int, value: int): Buffer {
    if (offset + 2 > buf.capacity) {
        var new_buf: Buffer = buffer_resize(buf, offset + 2);
