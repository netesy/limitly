// Compatibility facade: core contains Option/Result frames.
import std.core as core;

var OptionInt = core.OptionInt;
var OptionStr = core.OptionStr;
var ResultInt = core.ResultInt;
var ResultStr = core.ResultStr;

var some_int = core.some_int;
var none_int = core.none_int;
var some_str = core.some_str;
var none_str = core.none_str;
var ok_int = core.ok_int;
var err_int = core.err_int;
var ok_str = core.ok_str;
var err_str = core.err_str;
