// Custom element builder
fn custom(type_id: int, state_size: int): ui_types.Blueprint {
    var custom_data: ui_types.CustomData = ui_types.custom_data(type_id, state_size);
    return ui_types.Blueprint(
        variant=ui_types.ElementVariant.Custom(custom_data),
        constraints=[],
        children=[]
    );
}

// Custom element with render callback
fn custom_render(type_id: int, state_size: int, render_callback: ui_types.EventToken): ui_types.Blueprint {
    var custom_data: ui_types.CustomData = ui_types.custom_data(type_id, state_size);
    custom_data.render_callback = render_callback;
    return ui_types.Blueprint(
        variant=ui_types.ElementVariant.Custom(custom_data),
        constraints=[],
        children=[]
    );
}

// Constraint modifiers
fn fixed(size: int): ui_types.LayoutConstraint {
    return ui_types.LayoutConstraint.Fixed(size);
}

fn min_size(size: int): ui_types.LayoutConstraint {
    return ui_types.LayoutConstraint.Min(size);
}

fn max_size(size: int): ui_types.LayoutConstraint {
    return ui_types.LayoutConstraint.Max(size);
}

fn fill(): ui_types.LayoutConstraint {
    return ui_types.LayoutConstraint.Fill;
}

fn auto(): ui_types.LayoutConstraint {
    return ui_types.LayoutConstraint.Auto;
}

// Apply constraint to blueprint
fn constrain(bp: ui_types.Blueprint, constraint: ui_types.LayoutConstraint): ui_types.Blueprint {
    return ui_types.blueprint_add_constraint(bp, constraint);
}

// Apply width constraint
fn width(bp: ui_types.Blueprint, width: int): ui_types.Blueprint {
    return ui_types.blueprint_add_constraint(bp, ui_types.LayoutConstraint.Fixed(width));
}

// Apply height constraint
fn height(bp: ui_types.Blueprint, height: int): ui_types.Blueprint {
    return ui_types.blueprint_add_constraint(bp, ui_types.LayoutConstraint.Fixed(height));
}

// Apply min width constraint
fn min_width(bp: ui_types.Blueprint, min_width: int): ui_types.Blueprint {
    return ui_types.blueprint_add_constraint(bp, ui_types.LayoutConstraint.Min(min_width));
}

// Apply min height constraint
fn min_height(bp: ui_types.Blueprint, min_height: int): ui_types.Blueprint {
    return ui_types.blueprint_add_constraint(bp, ui_types.LayoutConstraint.Min(min_height));
}

// Apply max width constraint
fn max_width(bp: ui_types.Blueprint, max_width: int): ui_types.Blueprint {
    return ui_types.blueprint_add_constraint(bp, ui_types.LayoutConstraint.Max(max_width));
}

// Apply max height constraint
fn max_height(bp: ui_types.Blueprint, max_height: int): ui_types.Blueprint {
    return ui_types.blueprint_add_constraint(bp, ui_types.LayoutConstraint.Max(max_height));
}

// Apply fill constraint
fn fill_width(bp: ui_types.Blueprint): ui_types.Blueprint {
    return ui_types.blueprint_add_constraint(bp, ui_types.LayoutConstraint.Fill);
}

fn fill_height(bp: ui_types.Blueprint): ui_types.Blueprint {
    return ui_types.blueprint_add_constraint(bp, ui_types.LayoutConstraint.Fill);
}

fn fill(bp: ui_types.Blueprint): ui_types.Blueprint {
    var bp1: ui_types.Blueprint = ui_types.blueprint_add_constraint(bp, ui_types.LayoutConstraint.Fill);
    return ui_types.blueprint_add_constraint(bp1, ui_types.LayoutConstraint.Fill);
}

// Apply auto constraint
fn auto_width(bp: ui_types.Blueprint): ui_types.Blueprint {
    return ui_types.blueprint_add_constraint(bp, ui_types.LayoutConstraint.Auto);
}

fn auto_height(bp: ui_types.Blueprint): ui_types.Blueprint {
    return ui_types.blueprint_add_constraint(bp, ui_types.LayoutConstraint.Auto);
}

fn auto(bp: ui_types.Blueprint): ui_types.Blueprint {
    var bp1: ui_types.Blueprint = ui_types.blueprint_add_constraint(bp, ui_types.LayoutConstraint.Auto);
    return ui_types.blueprint_add_constraint(bp1, ui_types.LayoutConstraint.Auto);
}

// Padding helper
fn padding(all: float): ui_types.Rect {
    return ui_types.rect(all, all, all, all);
}

fn padding_xy(x: float, y: float): ui_types.Rect {
    return ui_types.rect(x, y, x, y);
}

fn padding_ltrb(left: float, top: float, right: float, bottom: float): ui_types.Rect {
    return ui_types.rect(left, top, right, bottom);
}

// Spacing helpers
fn spacing_small(): float {
    return 4.0;
}

fn spacing_medium(): float {
    return 8.0;
}

fn spacing_large(): float {
    return 16.0;
}

fn spacing_xlarge(): float {
    return 24.0;
}

// Color helpers
fn color_hex(hex: int): ui_types.Color {
    var r: float = ((hex >> 16) & 0xFF) as float / 255.0;
    var g: float = ((hex >> 8) & 0xFF) as float / 255.0;
    var b: float = (hex & 0xFF) as float / 255.0;
    var a: float = ((hex >> 24) & 0xFF) as float / 255.0;
    return ui_types.color_rgba(r, g, b, a);
}

fn color_rgb8(r: int, g: int, b: int): ui_types.Color {
    return ui_types.color_rgb(r as float / 255.0, g as float / 255.0, b as float / 255.0);
}

fn color_rgba8(r: int, g: int, b: int, a: int): ui_types.Color {
    return ui_types.color_rgba(r as float / 255.0, g as float / 255.0, b as float / 255.0, a as float / 255.0);
}

// Size helpers
fn size_points(width: float, height: float): ui_types.Size {
    return ui_types.size(width, height);
}

fn size_square(size: float): ui_types.Size {
    return ui_types.size(size, size);
}

// Point helpers
fn point_xy(x: float, y: float): ui_types.Point {
    return ui_types.point(x, y);
}

// Compose blueprints (add child)
fn add_child(parent: ui_types.Blueprint, child: ui_types.Blueprint): ui_types.Blueprint {
    return ui_types.blueprint_add_child(parent, child);
}

// Compose multiple children
fn add_children(parent: ui_types.Blueprint, children: [ui_types.Blueprint]): ui_types.Blueprint {
    var result: ui_types.Blueprint = parent;
    var i: int = 0;
    while (i < len(children)) {
        result = ui_types.blueprint_add_child(result, children[i]);
        i = i + 1;
    }
    return result;
}

// Empty blueprint
fn empty(): ui_types.Blueprint {
    return ui_types.Blueprint(
        variant=ui_types.ElementVariant.Container(ui_types.container_data(ui_types.Axis.Vertical)),
        constraints=[],
        children=[]
    );
}

// Spacer (invisible element for spacing)
fn spacer(width: float, height: float): ui_types.Blueprint {
    var container_data: ui_types.ContainerData = ui_types.container_data(ui_types.Axis.Vertical);
    return ui_types.Blueprint(
        variant=ui_types.ElementVariant.Container(container_data),
        constraints=[ui_types.LayoutConstraint.Fixed(width as int), ui_types.LayoutConstraint.Fixed(height as int)],
        children=[]
    );
}

fn spacer_width(width: float): ui_types.Blueprint {
    return spacer(width, 0.0);
}

fn spacer_height(height: float): ui_types.Blueprint {
    return spacer(0.0, height);
}

// Divider line
fn divider(): ui_types.Blueprint {
    var container_data: ui_types.ContainerData = ui_types.container_data(ui_types.Axis.Horizontal);
    container_data.background = ui_types.color_rgb8(200, 200, 200);
    return ui_types.Blueprint(
        variant=ui_types.ElementVariant.Container(container_data),
        constraints=[ui_types.LayoutConstraint.Fixed(1)],
        children=[]
    );
}

// Center content
fn center(child: ui_types.Blueprint): ui_types.Blueprint {
    return hstack_alignment(ui_types.Alignment.Center, [child]);
}

// Expand to fill available space
fn expand(child: ui_types.Blueprint): ui_types.Blueprint {
    var child_constrained: ui_types.Blueprint = ui_types.blueprint_add_constraint(child, ui_types.LayoutConstraint.Fill);
    return hstack([child_constrained]);
}
