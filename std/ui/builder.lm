// Scroll builder
fn scroll(axis: ui_types.Axis, content: ui_types.Blueprint): ui_types.Blueprint {
    var scroll_data: ui_types.ScrollData = ui_types.scroll_data(axis);
    return ui_types.Blueprint(
        variant=ui_types.ElementVariant.Scroll(scroll_data),
        constraints=[],
        children=[content]
    );
}

