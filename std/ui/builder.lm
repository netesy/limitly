// UI Builder Module
// Declarative builder API for constructing UI blueprints

import std.ui.types as ui_types;

// VStack builder (vertical stack container)
fn vstack(children: [ui_types.Blueprint]): ui_types.Blueprint {
    var container_data: ui_types.ContainerData = ui_types.container_data(ui_types.Axis.Vertical);
    return ui_types.Blueprint(
        variant=ui_types.ElementVariant.Container(container_data),
        constraints=[],
        children=children
    );
}

// VStack with spacing
fn vstack_spacing(spacing: float, children: [ui_types.Blueprint]): ui_types.Blueprint {
    var container_data: ui_types.ContainerData = ui_types.container_data(ui_types.Axis.Vertical);
    container_data.spacing = spacing;
    return ui_types.Blueprint(
        variant=ui_types.ElementVariant.Container(container_data),
        constraints=[],
        children=children
    );
}

// VStack with padding
fn vstack_padding(padding: ui_types.Rect, children: [ui_types.Blueprint]): ui_types.Blueprint {
    var container_data: ui_types.ContainerData = ui_types.container_data(ui_types.Axis.Vertical);
    container_data.padding = padding;
    return ui_types.Blueprint(
        variant=ui_types.ElementVariant.Container(container_data),
        constraints=[],
        children=children
    );
}

