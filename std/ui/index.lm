// UI Module Index
// Main entry point for the UI framework

import std.ui.types as types;
import std.ui.context as context;
import std.ui.builder as builder;

// Re-export commonly used types
var Blueprint = types.Blueprint;
var Element = types.Element;
var ElementId = types.ElementId;
var EventToken = types.EventToken;
var Color = types.Color;
var Size = types.Size;
var Point = types.Point;
var Rect = types.Rect;
var LayoutMetrics = types.LayoutMetrics;
var RenderCommand = types.RenderCommand;
var UIEvent = types.UIEvent;
var StateValue = types.StateValue;

// Re-export commonly used functions
var ui_init = context.ui_init;
var ui_shutdown = context.ui_shutdown;
var frame_update = context.frame_update;
var update_blueprint = context.update_blueprint;
var create_state = context.create_state;
var get_state = context.get_state;
var set_state = context.set_state;
var subscribe_state = context.subscribe_state;
var register_event_handler = context.register_event_handler;

// Re-export builder functions
var vstack = builder.vstack;
var vstack_spacing = builder.vstack_spacing;
