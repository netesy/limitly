        while (i < self.data.length) {
            if (f(self.data[i])) return self.data[i];
            i = i + 1;
        }
        return nil;
    }

    pub fn contains(value: int): bool {
        var i: int = 0;
        while (i < self.data.length) {
            if (self.data[i] == value) return true;
            i = i + 1;
        }
        return false;
    }

    pub fn any(f: fn(int): bool): bool {
        var i: int = 0;
        while (i < self.data.length) {
            if (f(self.data[i])) return true;
            i = i + 1;
        }
        return false;
    }

    pub fn all(f: fn(int): bool): bool {
        var i: int = 0;
        while (i < self.data.length) {
            if (!f(self.data[i])) return false;
            i = i + 1;
        }
        return true;
    }
}

// Frame-focused collections - use List frame directly
// Example: List(data=[1,2,3]).push(4) instead of push([1,2,3], 4)

// Pure utility functions that don't duplicate frame functionality
fn find_index(arr: [int], item: int): int? {
    var i: int = 0;
    while (i < arr.length) {
        if (arr[i] == item) return i;
        i = i + 1;
    }
    return nil;
}

// String-specific join utility (different from List operations)
fn join_string_array(arr: [str], separator: str): str {
    if (arr.length == 0) return "";
    var out: str = arr[0];
    var i: int = 1;
    while (i < arr.length) {
        out = out + separator + arr[i];
        i = i + 1;
    }
    return out;
}
